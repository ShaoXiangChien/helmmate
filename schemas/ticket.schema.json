{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/dev-board/ticket.schema.json",
  "title": "Dev Board Ticket",
  "type": "object",
  "required": [
    "id",
    "title",
    "status",
    "priority",
    "repo",
    "depends_on",
    "description",
    "acceptance_criteria",
    "context_refs",
    "branch",
    "notes"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "epic": { "type": "string" },
    "status": { "type": "string" },
    "priority": { "type": "string" },
    "repo": { "type": "string" },
    "depends_on": { "type": "array", "items": { "type": "string" } },
    "size": { "type": "string" },
    "description": { "type": "string" },
    "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
    "context_refs": { "type": "array", "items": { "type": "string" } },
    "branch": { "type": "string" },
    "pr_url": { "type": ["string", "null"] },
    "pr_urls": { "type": "array", "items": { "type": "string" } },
    "source": { "type": "string" },
    "created": { "type": "string" },
    "updated": { "type": "string" },
    "notes": { "type": "array", "items": { "type": "string" } },
    "queued_reason": { "type": "string", "enum": ["disarmed", "wip_limit"] },
    "queued_detail": { "type": "string" },
    "queued_at": { "type": "string" },
    "custom": { "type": "object" },
    "metadata": { "type": "object" }
  },
  "additionalProperties": true
}
